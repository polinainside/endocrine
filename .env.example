# Скопируйте в .env.local и подставьте значения.

# ИИ-интерпретация и распознавание (Mistral). Бесплатный ключ: https://console.mistral.ai/
MISTRAL_API_KEY=
# MISTRAL_MODEL=mistral-small-latest
# MISTRAL_VISION_MODEL=pixtral-12b-2409

# Калории из базы USDA. Бесплатный ключ: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=

# Supabase (бэкенд: auth + БД + storage). Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role — секретный, только на сервере, НЕ префикс NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=
